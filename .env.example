# Database
DATABASE_URL=

# Frappe Cloud (Press API auth)
FC_API_KEY=
FC_API_SECRET=

# Google Chat
GOOGLE_CHAT_WEBHOOK=
GOOGLE_CHAT_WEBHOOK_TESTING=
GOOGLE_CHAT_WEBHOOK_GITHUB=

# GitHub
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
GITHUB_WEBHOOK_TOKEN=

# Inbound API/Webhook security (recommended)
# Set INBOUND_SHARED_TOKEN for one shared secret across protected endpoints.
# Or set per-endpoint tokens below for stricter separation.
INBOUND_SHARED_TOKEN=
FRAPPE_CLOUD_WEBHOOK_TOKEN=
DEPLOY_WORKFLOW_TOKEN=
DEPLOY_STATUS_TOKEN=

# Frappe Cloud environment mapping (recommended: set in env, not in code)
# Example:
# SITE_ENV_MAP_JSON={"your-site.example.com":"Staging","your-prod.example.com":"Production"}
# BENCH_ENV_MAP_JSON={"bench-123":"Staging","bench-456":"Production"}
SITE_ENV_MAP_JSON=
BENCH_ENV_MAP_JSON=

# Auto deploy runner
DEPLOY_ENV=staging
STAGING_BENCH_NAME=bench-XXXXX
PREVIEW_BENCH_NAME=bench-XXXXX
PROD_BENCH_NAME=bench-XXXXX
VERSION16_BENCH_NAME=bench-XXXXX
STAGING_ALLOWED_APPS=
PREVIEW_ALLOWED_APPS=
PROD_ALLOWED_APPS=
VERSION16_ALLOWED_APPS=
ALLOWED_APPS_FROM_WORKFLOW=

# Server runtime
PORT=8080
APP_DEBUG=
LOG_LEVEL=INFO

# Timeouts (seconds)
PRESS_API_TIMEOUT_SECONDS=30
GITHUB_API_TIMEOUT_SECONDS=15
GOOGLE_CHAT_TIMEOUT_SECONDS=10
